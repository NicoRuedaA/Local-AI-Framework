{
  "$schema": "https://opencode.ai/config.json",
  "model": "auto",

  "mcp": {
    "unityMCP": {
      "type": "remote",
      "url": "http://localhost:8080/mcp",
      "enabled": false
    }
  },

  "agent": {
    "orquestador": {
      "prompt": "./agents/orquestador.md",
      "temperature": 0.1,
      "permission": { 
        "edit": "allow", 
        "bash": "allow" 
      }
    },
    "planificador": {
      "prompt": "./agents/planificador.md",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": { 
        "edit": "deny", 
        "bash": "deny" 
      }
    },
    "arquitecto": {
      "prompt": "./agents/arquitecto.md",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": { 
        "edit": "allow", 
        "bash": "deny" 
      }
    },
    "constructor": {
      "prompt": "./agents/constructor.md",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": { 
        "edit": "allow", 
        "bash": "allow" 
      },
      "tools": {
        "unityMCP*": true
      }
    },
    "guardia": {
      "prompt": "./agents/guardia.md",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": { 
        "edit": "deny", 
        "bash": "deny" 
      }
    },
    "detective": {
      "prompt": "./agents/detective.md",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": { 
        "edit": "allow", 
        "bash": "allow" 
      },
      "tools": {
        "unityMCP_read_console": true,
        "unityMCP_find_gameobjects": true
      }
    },
    "critico": {
      "prompt": "./agents/critico.md",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": { 
        "edit": "deny", 
        "bash": "deny" 
      }
    },
    "optimizador": {
      "prompt": "./agents/optimizador.md",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": { 
        "edit": "allow", 
        "bash": "allow" 
      }
    },
    "escudo": {
      "prompt": "./agents/escudo.md",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": { 
        "edit": "allow", 
        "bash": "allow" 
      }
    },
    "narrador": {
      "prompt": "./agents/narrador.md",
      "mode": "subagent",
      "temperature": 0.3,
      "permission": { 
        "edit": "allow", 
        "bash": "deny" 
      }
    },
    "memoria": {
      "prompt": "./agents/memoria.md",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": { 
        "edit": "deny", 
        "bash": "deny" 
      }
    }
  }
}